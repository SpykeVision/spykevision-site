---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Donate from '../components/Donate.astro';
const { title, description, active, theme = 'light' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme={theme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="alternate" type="application/rss+xml" title="SpykeVision Reviews" href="/rss.xml" />
  <!-- Before/after comparison slider (web component) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/styles.css" />
  <script type="module" src="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/index.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2/dist/chartjs-plugin-datalabels.min.js"></script>
</head>
<body>
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
    <span class="theme-icon">☀️</span>
    <span class="theme-label">Light</span>
  </button>

  <Header active={active} />

  <slot />

  <Footer />

  <Donate />

  <button class="scroll-top" id="scrollTop" aria-label="Back to top">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
  </button>
  <button class="scroll-bottom" id="scrollBottom" aria-label="Go to bottom">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
  </button>

  <script is:inline src="/js/main.js"></script>
  <script is:inline src="/js/compare.js"></script>
  <script is:inline src="/js/charts-tnm.js"></script>
  <script is:inline src="/js/charts-tnm-cards.js"></script>
  <script is:inline src="/js/enh-compare.js"></script>
  <!-- Cloudflare Web Analytics --><script is:inline defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "92363d386413401286d548d138515fea"}'></script><!-- End Cloudflare Web Analytics -->
</body>
</html>
