---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const reviews = (await getCollection('reviews-ru'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base
  title="Обзоры | SpykeVision"
  description="Все обзоры проекторов SpykeVision на основе измерений."
  active="reviews"
>
  <main class="wrap">
    <div class="article-hero">
      <h1>Обзоры</h1>
    </div>

    {reviews.length === 0 ? (
      <p style="color:var(--text-3)">Обзоры ещё не опубликованы. Заходите позже.</p>
    ) : (
      <div class="grid" style="margin-bottom:60px">
        {reviews.map((r) => (
          <a href={`/ru/reviews/${r.slug}/`} class="card" data-draft={r.data.draft ? 'true' : null}>
            <div class="card-media">
              <img src={r.data.cover} alt={r.data.title} />
              {r.data.badge ? <div class="card-badge">{r.data.badge}</div> : (r.data.score != null && <div class="score">{r.data.score.toFixed(1)}</div>)}
            </div>
            <div class="card-body">
              {r.data.draft && <span class="draft-badge">Черновик</span>}
              {r.data.category && <span class="card-cat">{r.data.category}</span>}
              <h3>{r.data.title}</h3>
              <p>{r.data.summary}</p>
              <div class="card-meta">
                <span class="author"><span class="avatar"></span>SpykeSIK</span>
                <span>•</span><span>{new Date(r.data.date).toLocaleDateString('ru-RU',{year:'numeric',month:'short'})}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</Base>
