---
import Base from '../../layouts/Base.astro';
import c from '../../data/contact.ru.json';
---
<Base
  title={c.meta.title}
  description={c.meta.description}
  active="contact"
>
  <main class="wrap">
    <div class="article-hero">
      <h1>{c.heading}</h1>
    </div>

    <div class="contact-wrap">
      <div class="contact-card">
        <p class="contact-name">{c.card.name}</p>
        <p class="contact-line">{c.card.text}</p>
        <div style="margin-top:20px">
          <p class="contact-line" style="margin-bottom:8px;font-weight:600;opacity:1">{c.card.activeLabel}</p>
          <a href={c.card.forumUrl} target="_blank" rel="noopener" class="contact-forum">{c.card.forumLabel}</a>
        </div>
      </div>

      <form class="contact-form" id="contactForm">
        <input type="hidden" name="access_key" value="87fe1b0f-1e6d-4ddd-9dd7-dad928ae315b" />
        <input type="hidden" name="subject" value={c.form.emailSubject} />
        <input type="hidden" name="from_name" value="SpykeVision website" />
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
        <div class="form-group">
          <label>{c.form.nameLabel}</label>
          <input type="text" name="name" placeholder={c.form.namePlaceholder} required />
        </div>
        <div class="form-group">
          <label>{c.form.emailLabel}</label>
          <input type="email" name="email" placeholder={c.form.emailPlaceholder} required />
        </div>
        <div class="form-group">
          <label>{c.form.subjectLabel}</label>
          <input type="text" name="topic" placeholder={c.form.subjectPlaceholder} />
        </div>
        <div class="form-group">
          <label>{c.form.messageLabel}</label>
          <textarea name="message" placeholder={c.form.messagePlaceholder} rows="5" required></textarea>
        </div>
        <button type="submit" class="btn">{c.form.submitLabel}</button>
        <p class="form-status" id="formStatus" aria-live="polite"></p>
      </form>
    </div>
  </main>
</Base>
