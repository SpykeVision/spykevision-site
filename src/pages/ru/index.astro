---
import Base from '../../layouts/Base.astro';
import Subscribe from '../../components/Subscribe.astro';
import { getCollection } from 'astro:content';
import home from '../../data/home.ru.json';

const reviews = (await getCollection('reviews-ru'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base
  title={home.meta.title}
  description={home.meta.description}
  active="reviews"
>
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">{home.hero.eyebrow}</p>
      <h1>{home.hero.heading}</h1>
      <p>{home.hero.text}</p>
      <a href="/ru/reviews/" class="btn">{home.hero.ctaLabel}</a>
    </div>
  </section>

  <main class="wrap">
    {reviews.length > 0 && (
      <section class="section" id="reviews">
        <div class="section-head"><h2>{home.headings.latest}</h2><a href="/ru/reviews/">{home.headings.allReviews}</a></div>
        <div class="grid">
          {reviews.slice(0, 6).map((r, i) => (
            <a href={`/ru/reviews/${r.slug}/`} class={`card${i === 0 ? ' featured' : ''}`} data-draft={r.data.draft ? 'true' : null}>
              <div class="card-media">
                <img src={r.data.coverCard || r.data.cover} alt={r.data.title} />
                {r.data.badge ? <div class="card-badge">{r.data.badge}</div> : (r.data.score != null && <div class="score">{r.data.score.toFixed(1)}</div>)}
              </div>
              <div class="card-body">
                {r.data.draft && <span class="draft-badge">Черновик</span>}
                {r.data.category && <span class="card-cat">{r.data.category}</span>}
                <h3>{r.data.title}</h3>
                <p>{r.data.summary}</p>
                <div class="card-meta">
                  <span class="author"><span class="avatar"></span>SpykeSIK</span>
                  <span>•</span><span>{new Date(r.data.date).toLocaleDateString('ru-RU',{year:'numeric',month:'short'})}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="section" id="coming-soon">
      <div class="section-head"><h2>{home.headings.comingSoon}</h2></div>
      <div class="cs-list">
        {home.comingSoon.map((c) => (
          <a href="#" class="cs-card">
            <div class="cs-media">
              {c.image && <img src={c.image} alt={c.title} class="cs-img" />}
              <div class="cs-badge">Скоро</div>
            </div>
            <div class="cs-body">
              <span class="card-cat">{c.category}</span>
              <h3>{c.title}</h3>
              <p>{c.text}</p>
              <div class="card-meta">
                <span class="author"><span class="avatar"></span>SpykeSIK</span>
                <span>•</span><span>{c.status}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="section" id="measurements">
      <div class="section-head"><h2>{home.headings.why}</h2></div>
      <div class="grid">
        {home.whyCards.map((c) => (
          <div class="card"><div class="card-body">
            <span class="card-cat" style={`color:var(--${c.color})`}>{c.tag}</span>
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div></div>
        ))}
      </div>
    </section>
  </main>

  <Subscribe lang="ru" />
</Base>
