---
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'about-en');
const { Content } = await page.render();
---
<Base title={page.data.title} description={page.data.description} active={page.data.active}>
  <main class="wrap">
    <div class="article-hero">
      <h1 style={page.data.centered ? 'text-align:center' : undefined}>{page.data.heroTitle}</h1>
      {page.data.showAuthor && <div class="article-meta"><span class="author"><span class="avatar"></span>SpykeSIK</span></div>}
    </div>

    <div class="prose">
      <Content />
    </div>
  </main>
</Base>
