---
import { getCollection } from 'astro:content';
import Review from '../../layouts/Review.astro';

export async function getStaticPaths() {
  // Build all slugs including drafts — draft pages are gated client-side.
  const reviews = await getCollection('reviews');
  return reviews.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
---
<Review review={entry.data} headings={headings}>
  <Content />
</Review>
