---
const { active } = Astro.props;
const logo = `<svg class="logo-mark" viewBox="0 0 32 32" aria-hidden="true"><defs><path id="bl" d="M29 16 L22.5 27.26 L18 19.46 Z"/></defs><use href="#bl" fill="#0a84ff"/><use href="#bl" transform="rotate(60 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(120 16 16)" fill="#ff9500"/><use href="#bl" transform="rotate(180 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(240 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(300 16 16)" fill="#0a84ff"/></svg>`;
---
<header class="site-header">
  <div class="wrap nav">
    <a href="/" class="brand"><Fragment set:html={logo} /><span class="wm">Spyke<span class="v">Vision</span><span class="beta-tag">beta</span></span></a>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false"><span></span></button>
    <ul class="nav-links">
      <li><a href="/reviews/" class={active === 'reviews' ? 'active' : ''}>Reviews</a></li>
      <li><a href="/#coming-soon">Coming Soon</a></li>
      <li><a href="/adl-calculator.html" class={active === 'calculator' ? 'active' : ''}>ADL Calculator<span class="beta-tag hot-tag">hot</span></a></li>
      <li><a href="/contact/" class={active === 'contact' ? 'active' : ''}>Contact</a></li>
      <li><a href="/about/" class={active === 'about' ? 'active' : ''}>About</a></li>
    </ul>
  </div>
</header>
