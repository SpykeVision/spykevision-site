---
const { active } = Astro.props;
const logo = `<svg class="logo-mark" viewBox="0 0 32 32" aria-hidden="true"><defs><path id="bl" d="M29 16 L22.5 27.26 L18 19.46 Z"/></defs><use href="#bl" fill="#0a84ff"/><use href="#bl" transform="rotate(60 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(120 16 16)" fill="#ff9500"/><use href="#bl" transform="rotate(180 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(240 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(300 16 16)" fill="#0a84ff"/></svg>`;
const currentPath = Astro.url.pathname;
const isRu = currentPath.startsWith('/ru');
const enHref = isRu ? currentPath.replace(/^\/ru/, '') || '/' : currentPath;
const ruHref = isRu ? currentPath : '/ru' + currentPath;

const flagEn = `<svg viewBox="0 0 30 20" width="22" height="15" class="flag-svg" aria-hidden="true">
  <rect width="30" height="20" fill="#B22234"/>
  <rect y="1.54" width="30" height="1.54" fill="#fff"/>
  <rect y="4.62" width="30" height="1.54" fill="#fff"/>
  <rect y="7.69" width="30" height="1.54" fill="#fff"/>
  <rect y="10.77" width="30" height="1.54" fill="#fff"/>
  <rect y="13.85" width="30" height="1.54" fill="#fff"/>
  <rect y="16.92" width="30" height="1.54" fill="#fff"/>
  <rect width="12" height="10.77" fill="#3C3B6E"/>
</svg>`;

const flagRu = `<svg viewBox="0 0 30 20" width="22" height="15" class="flag-svg" aria-hidden="true">
  <rect width="30" height="6.67" fill="#fff"/>
  <rect y="6.67" width="30" height="6.67" fill="#0039A6"/>
  <rect y="13.33" width="30" height="6.67" fill="#D52B1E"/>
</svg>`;

const currentFlag = isRu ? flagRu : flagEn;
---
<header class="site-header">
  <div class="wrap nav">
    <a href={isRu ? '/ru/' : '/'} class="brand"><Fragment set:html={logo} /><span class="wm">Spyke<span class="v">Vision</span><span class="beta-tag">beta</span></span></a>
    <a class="lang-flag-mobile" href={isRu ? enHref : ruHref} aria-label={isRu ? 'Switch to English' : 'Переключить на русский'}><Fragment set:html={isRu ? flagEn : flagRu} /></a>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false"><span></span></button>
    <ul class="nav-links">
      <li><a href={isRu ? '/ru/reviews/' : '/reviews/'} class={active === 'reviews' ? 'active' : ''}>{isRu ? 'Обзоры' : 'Reviews'}</a></li>
      <li><a href={isRu ? '/ru/#coming-soon' : '/#coming-soon'}>{isRu ? 'Скоро' : 'Coming Soon'}</a></li>
      <li><a href={isRu ? '/adl-calculator-ru.html' : '/adl-calculator.html'} class={active === 'calculator' ? 'active' : ''}>{isRu ? 'Калькулятор ADL' : 'ADL Calculator'}<span class="beta-tag hot-tag">hot</span></a></li>
      <li><a href={isRu ? '/ru/contact/' : '/contact/'} class={active === 'contact' ? 'active' : ''}>{isRu ? 'Контакты' : 'Contact'}</a></li>
      <li><a href={isRu ? '/ru/about/' : '/about/'} class={active === 'about' ? 'active' : ''}>{isRu ? 'О нас' : 'About'}</a></li>
      <li class="lang-dropdown-wrap">
        <button class="lang-dropdown-btn" aria-haspopup="true" aria-expanded="false" id="langDropBtn">
          <Fragment set:html={currentFlag} />
          <svg class="lang-chevron" viewBox="0 0 10 6" width="9" height="6" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
        </button>
        <ul class="lang-dropdown-menu" role="menu">
          <li role="menuitem"><a href={enHref} class={!isRu ? 'lang-active' : ''}><Fragment set:html={flagEn} /> English</a></li>
          <li role="menuitem"><a href={ruHref} class={isRu ? 'lang-active' : ''}><Fragment set:html={flagRu} /> Русский</a></li>
        </ul>
      </li>
    </ul>
  </div>
</header>

<script>
(function () {
  var btn = document.getElementById('langDropBtn');
  var menu = btn && btn.closest('.lang-dropdown-wrap').querySelector('.lang-dropdown-menu');
  if (!btn || !menu) return;
  function open()  { menu.classList.add('open'); btn.setAttribute('aria-expanded', 'true'); }
  function close() { menu.classList.remove('open'); btn.setAttribute('aria-expanded', 'false'); }
  btn.addEventListener('click', function(e) { e.stopPropagation(); menu.classList.contains('open') ? close() : open(); });
  document.addEventListener('click', close);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') close(); });
})();
</script>
