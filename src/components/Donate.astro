---
const USDT_ADDRESS = 'TUgTn5FUd4RUJWTLcu5YfZbcTQXjJPiCih';
const BOOSTY_URL   = 'https://boosty.to/spykevision';
---

<div class="donate-backdrop" id="donateBackdrop" aria-hidden="true"></div>

<dialog class="donate-modal" id="donateModal" aria-label="Support options">
  <button class="donate-close" id="donateClose" aria-label="Close">✕</button>
  <h2 class="donate-title">Support independent reviews</h2>
  <p class="donate-sub">No sponsors, no ads agenda — just readers keeping this going.</p>

  <div class="donate-options">

    <!-- Boosty -->
    <div class="donate-card">
      <div class="donate-card-icon boosty-icon">
        <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor"><path d="M16 3C8.82 3 3 8.82 3 16s5.82 13 13 13 13-5.82 13-13S23.18 3 16 3zm1.5 19.5h-3V17H10v-3h4.5V9.5h3V14H22v3h-4.5v5.5z"/></svg>
      </div>
      <div class="donate-card-body">
        <strong>Boosty</strong>
        <span class="donate-tag">RU / CIS</span>
        <p>Russian cards, МИР, SBP — for readers from Russia and CIS.</p>
      </div>
      <a href={BOOSTY_URL} target="_blank" rel="noopener" class="donate-action btn-boosty">Donate on Boosty →</a>
    </div>

    <!-- USDT -->
    <div class="donate-card">
      <div class="donate-card-icon usdt-icon">
        <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor"><path d="M16 2a14 14 0 1 0 0 28A14 14 0 0 0 16 2zm1 19.93V24h-2v-2.07C11.94 21.54 9.9 20.1 9 18l1.8-.9c.75 1.6 2.4 2.7 5.2 2.7 2.2 0 4-1 4-2.8 0-1.6-1.1-2.5-4-3.2-3.7-.9-5.8-2.3-5.8-5 0-2.4 1.7-4.2 4.8-4.7V2h2v2.07c2.8.46 4.6 2.1 5.2 4.3l-1.8.7c-.5-1.6-1.8-2.7-4.2-2.7-2.3 0-3.7 1.1-3.7 2.7 0 1.5 1 2.3 3.9 3 3.9.9 5.9 2.4 5.9 5.2 0 2.6-1.9 4.4-5.3 4.93z"/></svg>
      </div>
      <div class="donate-card-body">
        <strong>USDT</strong>
        <span class="donate-tag">TRC-20 · Worldwide</span>
        <p>Send any amount to the wallet address below.</p>
        <code class="donate-address" id="usdtAddr">{USDT_ADDRESS}</code>
      </div>
      <button class="donate-action btn-usdt" id="copyUsdt">Copy address</button>
    </div>

    <!-- Payoneer (stub) -->
    <div class="donate-card donate-card--soon">
      <div class="donate-card-icon payoneer-icon">
        <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor"><path d="M16 2a14 14 0 1 0 0 28A14 14 0 0 0 16 2zm-1 20v-3H9v-2h6v-3l5 4-5 4zm2-10V9l5 4-5 4V14H9v-2h8z"/></svg>
      </div>
      <div class="donate-card-body">
        <strong>Card / PayPal</strong>
        <span class="donate-tag">International</span>
        <p>Visa, Mastercard, Apple Pay — coming soon.</p>
      </div>
      <span class="donate-action btn-soon">Coming soon</span>
    </div>

  </div>
</dialog>

<style>
.donate-wrap {
  display: flex; flex-direction: column; align-items: center;
  gap: 10px; padding: 40px 20px 0; text-align: center;
}
.donate-hint { font-size: 14px; color: var(--text-3); }
.donate-btn {
  padding: 12px 28px; font-size: 15px; font-weight: 600;
  background: var(--accent); color: #fff; border: none;
  border-radius: 999px; cursor: pointer; transition: background .15s, transform .1s;
}
.donate-btn:hover { background: var(--accent-dk); transform: translateY(-1px); }

.donate-backdrop {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,.45); backdrop-filter: blur(4px);
  z-index: 200;
}
.donate-backdrop.open { display: block; }

.donate-modal {
  display: none; position: fixed; inset: 0; margin: auto;
  width: min(860px, 95vw); max-height: 90vh; overflow-y: auto;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); box-shadow: var(--shadow-lg);
  padding: 36px 32px 32px; z-index: 201;
}
.donate-modal.open { display: block; }

.donate-close {
  position: absolute; top: 16px; right: 16px;
  background: var(--surface-2); border: none; border-radius: 50%;
  width: 32px; height: 32px; font-size: 14px; cursor: pointer;
  color: var(--text-3); transition: color .15s, background .15s;
}
.donate-close:hover { background: var(--border); color: var(--text); }

.donate-title { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
.donate-sub { font-size: 14px; color: var(--text-3); margin-bottom: 24px; }

.donate-options {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
}
@media (max-width: 640px) { .donate-options { grid-template-columns: 1fr; } }

.donate-card {
  display: flex; flex-direction: column; gap: 10px;
  padding: 20px; border: 1px solid var(--border);
  border-radius: var(--radius-sm); background: var(--surface-2);
}
.donate-card--soon { opacity: .55; }

.donate-card-icon {
  width: 48px; height: 48px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
}
.boosty-icon   { background: #ff6b35; color: #fff; }
.usdt-icon     { background: #26a17b; color: #fff; }
.payoneer-icon { background: var(--border); color: var(--text-3); }

.donate-card-body { flex: 1; }
.donate-card-body strong { display: block; font-size: 16px; font-weight: 700; margin-bottom: 4px; }
.donate-card-body p { font-size: 13px; color: var(--text-2); margin-top: 4px; line-height: 1.5; }

.donate-tag {
  font-size: 11px; font-weight: 600; letter-spacing: .03em;
  color: var(--text-3); text-transform: uppercase;
}

.donate-address {
  display: block; margin-top: 8px; font-size: 11px;
  word-break: break-all; background: var(--surface);
  border: 1px solid var(--border); border-radius: 6px;
  padding: 6px 8px; color: var(--text-2); user-select: all;
}

.donate-action {
  display: block; text-align: center; padding: 10px 16px;
  border-radius: 8px; font-size: 14px; font-weight: 600;
  cursor: pointer; transition: opacity .15s, transform .1s; border: none;
}
.donate-action:hover { opacity: .85; transform: translateY(-1px); }

.btn-boosty   { background: #ff6b35; color: #fff; text-decoration: none; }
.btn-usdt     { background: #26a17b; color: #fff; }
.btn-soon     { background: var(--border); color: var(--text-3); cursor: default; }
.btn-soon:hover { transform: none; opacity: 1; }
</style>

<script>
(function () {
  var close = document.getElementById('donateClose');
  var modal = document.getElementById('donateModal');
  var backdrop = document.getElementById('donateBackdrop');
  var copy  = document.getElementById('copyUsdt');
  var addr  = document.getElementById('usdtAddr');

  function openModal() { modal.classList.add('open'); backdrop.classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeModal() { modal.classList.remove('open'); backdrop.classList.remove('open'); document.body.style.overflow = ''; }

  document.querySelectorAll('[data-donate-open]').forEach(function (el) {
    el.addEventListener('click', openModal);
  });
  close.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

  copy.addEventListener('click', function () {
    navigator.clipboard.writeText(addr.textContent.trim()).then(function () {
      copy.textContent = 'Copied ✓';
      setTimeout(function () { copy.textContent = 'Copy address'; }, 2000);
    });
  });
})();
</script>
