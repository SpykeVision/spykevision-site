---
const logo = `<svg class="logo-mark" viewBox="0 0 32 32" aria-hidden="true"><defs><path id="bl" d="M29 16 L22.5 27.26 L18 19.46 Z"/></defs><use href="#bl" fill="#0a84ff"/><use href="#bl" transform="rotate(60 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(120 16 16)" fill="#ff9500"/><use href="#bl" transform="rotate(180 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(240 16 16)" fill="#0a84ff"/><use href="#bl" transform="rotate(300 16 16)" fill="#0a84ff"/></svg>`;
const isRu = Astro.url.pathname.startsWith('/ru');
const base = isRu ? '/ru' : '';
---
<footer class="site-footer">
  <div class="wrap footer-inner">
    <a href={isRu ? '/ru/' : '/'} class="brand"><Fragment set:html={logo} /><span class="wm">Spyke<span class="v">Vision</span><span class="beta-tag">beta</span></span></a>
    <nav class="footer-links">
      <a href={`${base}/reviews/`}>{isRu ? 'Обзоры' : 'Reviews'}</a>
      <a href={`${base}/contact/`}>{isRu ? 'Контакты' : 'Contact'}</a>
      <a href={`${base}/about/`}>{isRu ? 'О нас' : 'About'}</a>
      <a href="/privacy/">Privacy</a>
      <a href="/rss.xml">RSS</a>
    </nav>
    <div class="footer-social">
      <a href="https://www.avsforum.com/members/spykesik.8223142/" target="_blank" rel="noopener" aria-label="AVS Forum" title="AVS Forum — SpykeSIK">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
          <rect x="1" y="4" width="22" height="4" rx="1"/>
          <rect x="1" y="10" width="22" height="4" rx="1"/>
          <rect x="1" y="16" width="22" height="4" rx="1"/>
        </svg>
      </a>
      <a href="https://www.youtube.com/" target="_blank" rel="noopener" aria-label="YouTube" title="YouTube">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.6 15.6V8.4l6.2 3.6-6.2 3.6z"/></svg>
      </a>
    </div>
    <p class="copyright">© 2026 SpykeVision. {isRu ? 'Независимое издание.' : 'Independent & reader-supported.'}</p>
    <button class="footer-support-btn" data-donate-open>{isRu ? 'Поддержать' : 'Donate'}</button>
  </div>
</footer>
