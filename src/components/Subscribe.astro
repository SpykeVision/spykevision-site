---
// MailerLite embedded form.
// After registering at mailerlite.com:
//   1. Go to Forms → Create embedded form
//   2. In the embed code find ml('account', 'XXXXXX') → paste ACCOUNT_ID below
//   3. Copy the data-form="XXXXXX" value → paste FORM_ID below
const ACCOUNT_ID = ''; // e.g. '123456'
const FORM_ID    = ''; // e.g. 'a1b2c3d4'
const enabled = ACCOUNT_ID !== '' && FORM_ID !== '';
---
{enabled && (
  <section class="subscribe-section">
    <div class="wrap subscribe-inner">
      <div class="subscribe-text">
        <h3>New reviews in your inbox</h3>
        <p>When a new review drops — you'll know. No spam, unsubscribe any time.</p>
      </div>
      <div class="subscribe-form">
        <div class="ml-embedded" data-form={FORM_ID}></div>
      </div>
    </div>
    <script define:vars={{ ACCOUNT_ID }} is:inline>
      (function(w,d,e,u,f,l,n){
        w[f]=w[f]||function(){(w[f].q=w[f].q||[]).push(arguments);};
        l=d.createElement(e);l.async=1;l.src=u;
        n=d.getElementsByTagName(e)[0];n.parentNode.insertBefore(l,n);
      })(window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
      ml('account', ACCOUNT_ID);
    </script>
  </section>
)}
