---
const { lang = 'en' } = Astro.props;
const ACCOUNT_ID = '2448508';
const FORM_ID    = '8lzoBZ';
const enabled = ACCOUNT_ID !== '' && FORM_ID !== '';
const heading = lang === 'ru' ? 'Новые обзоры на почту' : 'New reviews in your inbox';
const subtext = lang === 'ru'
  ? 'Когда выйдет новый обзор — узнаете первыми. Без спама, отписка в один клик.'
  : "When a new review drops — you'll know. No spam, unsubscribe any time.";
---
{enabled && (
  <section class="subscribe-section">
    <div class="wrap subscribe-inner">
      <div class="subscribe-text">
        <h3>{heading}</h3>
        <p>{subtext}</p>
      </div>
      <div class="subscribe-form">
        <div class="ml-embedded" data-form={FORM_ID}></div>
      </div>
    </div>
    <script define:vars={{ ACCOUNT_ID }} is:inline>
      (function(w,d,e,u,f,l,n){
        w[f]=w[f]||function(){(w[f].q=w[f].q||[]).push(arguments);};
        l=d.createElement(e);l.async=1;l.src=u;
        n=d.getElementsByTagName(e)[0];n.parentNode.insertBefore(l,n);
      })(window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
      ml('account', ACCOUNT_ID);

      // Patch border-radius after MailerLite renders (it injects HTML dynamically)
      var mlTarget = document.querySelector('.ml-embedded');
      if (mlTarget) {
        var mlObs = new MutationObserver(function() {
          mlTarget.querySelectorAll('*').forEach(function(el) {
            var tag = el.tagName.toLowerCase();
            var cls = el.className || '';
            if (
              cls.indexOf('Wrapper') > -1 ||
              cls.indexOf('Container') > -1 ||
              cls.indexOf('embedBody') > -1 ||
              tag === 'input' || tag === 'button' || tag === 'textarea'
            ) {
              el.style.setProperty('border-radius', '12px', 'important');
            }
          });
        });
        mlObs.observe(mlTarget, { childList: true, subtree: true });
      }
    </script>
  </section>
)}
