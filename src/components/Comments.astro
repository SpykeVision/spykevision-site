---
// Giscus comments (GitHub Discussions). After enabling Discussions on the repo
// and configuring at https://giscus.app, paste the two IDs below.
// Until both are filled, the comments block stays hidden — nothing breaks.
const REPO = 'SpykeVision/spykevision-site';
const REPO_ID = 'R_kgDOSyqTPw';
const CATEGORY = 'Announcements';
const CATEGORY_ID = 'DIC_kwDOSyqTP84C-rd9';
const enabled = Boolean(REPO_ID && CATEGORY_ID);
---
{enabled && (
  <section class="comments article-page wrap">
    <h2 class="comments-title">Comments</h2>
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo={REPO}
      data-repo-id={REPO_ID}
      data-category={CATEGORY}
      data-category-id={CATEGORY_ID}
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="preferred_color_scheme"
      data-lang="ru"
      crossorigin="anonymous"
      async
    ></script>
  </section>
)}
