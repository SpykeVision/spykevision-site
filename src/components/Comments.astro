---
// Disqus comments — anyone can comment (name + email, no account required).
// 1. Go to https://disqus.com/admin/create/ and create a site.
// 2. Set SHORTNAME to your Disqus site shortname (e.g. "spykevision").
// Until SHORTNAME is filled, the section stays hidden.
const SHORTNAME = 'spykevision';
const enabled = Boolean(SHORTNAME);
---
{enabled && (
  <section class="comments article-page wrap">
    <h2 class="comments-title">Comments</h2>
    <div id="disqus_thread"></div>
    <script is:inline define:vars={{ SHORTNAME }}>
      var disqus_config = function () {
        this.page.url  = window.location.href;
        this.page.identifier = window.location.pathname;
      };
      (function () {
        var d = document, s = d.createElement('script');
        s.src = 'https://' + SHORTNAME + '.disqus.com/embed.js';
        s.setAttribute('data-timestamp', +new Date());
        (d.head || d.body).appendChild(s);
      })();
    </script>
    <noscript>
      Please enable JavaScript to view the
      <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a>
    </noscript>
  </section>
)}
