---
// Cusdis comments — no account required, name + email only.
// 1. Sign up at https://cusdis.com and create an app.
// 2. Paste your App ID (Settings → General → App ID) into APP_ID below.
const APP_ID = 'fb2e9de2-0050-4d4d-8004-8eda40b1fafc';

const { title } = Astro.props;
const pageUrl = Astro.url.href;
const pageId  = Astro.url.pathname;
const enabled = APP_ID !== 'YOUR_CUSDIS_APP_ID';
---
{enabled && (
  <section class="comments article-page wrap">
    <h2 class="comments-title">Comments</h2>
    <div
      id="cusdis_thread"
      data-host="https://cusdis.com"
      data-app-id={APP_ID}
      data-page-id={pageId}
      data-page-url={pageUrl}
      data-page-title={title ?? pageId}
    ></div>
    <script async defer src="https://cusdis.com/js/cusdis.es.js"></script>
    <script>
      // Cusdis renders inside a srcdoc iframe (same-origin) — inject styles directly
      const thread = document.getElementById('cusdis_thread');
      if (thread) {
        const obs = new MutationObserver(() => {
          const iframe = thread.querySelector('iframe');
          if (!iframe || iframe.dataset.patched) return;
          iframe.dataset.patched = '1';
          iframe.addEventListener('load', () => {
            try {
              const doc = iframe.contentDocument;
              if (!doc) return;
              // Inject CSS immediately (applies even before React renders)
              const style = doc.createElement('style');
              style.textContent = `
                textarea { min-height: 120px !important; }
                label::after { content: ' *'; color: #e53e3e; font-size: 12px; }
              `;
              doc.head.appendChild(style);
              // Watch for React to render labels, then fix Email text
              const inner = new MutationObserver(() => {
                doc.querySelectorAll('label').forEach(l => {
                  if (l.textContent.includes('optional')) {
                    l.textContent = 'Email';
                    inner.disconnect();
                  }
                });
              });
              inner.observe(doc.body, { childList: true, subtree: true });
            } catch (e) {}
          });
        });
        obs.observe(thread, { childList: true });
      }
    </script>
  </section>
)}
